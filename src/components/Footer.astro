---
import Linkedin from './icons/Linkedin.astro';
import Instagram from './icons/Instagram.astro';
import Youtube from './icons/Youtube.astro';
import { footerColumns, socials, footerAbout } from '../data/site';

const icons = { linkedin: Linkedin, instagram: Instagram, youtube: Youtube };
const year = 2026;
---

<footer class="bg-gray-50">
  <div class="mx-auto max-w-[1440px] px-5 pt-16 lg:px-[120px] lg:pt-20">
    <!-- Top -->
    <div class="flex flex-col gap-12 border-b border-gray-100 pb-12 lg:flex-row lg:justify-between lg:pb-20">
      <!-- Brand -->
      <div class="flex flex-col items-start gap-6 lg:max-w-[286px] lg:gap-[34px]">
        <img
          src="/images/logotipo-salestime.svg"
          alt="Salestime"
          width="200"
          height="41"
          class="h-[41px] w-[200px] max-w-full"
        />
        <p class="text-sm font-medium leading-[1.5] text-gray-900">{footerAbout}</p>
      </div>

      <!-- Colunas + social -->
      <div class="flex flex-col gap-10 sm:flex-row lg:gap-[120px]">
        {footerColumns.map((col) => (
          <nav class="flex flex-col gap-[14px]" aria-label={col.title}>
            <p class="text-base font-semibold text-blue-600">{col.title}</p>
            <ul class="flex flex-col gap-[14px]">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm font-semibold leading-[1.4] text-gray-900 transition-colors hover:text-blue-600"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))}

        <div class="flex flex-col gap-[14px]">
          <p class="text-sm font-bold text-blue-600">Siga a Salestime</p>
          <ul class="flex gap-3">
            {socials.map((social) => {
              const Icon = icons[social.icon as keyof typeof icons];
              return (
                <li>
                  <a
                    href={social.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={social.label}
                    class="inline-flex size-9 items-center justify-center rounded-full bg-blue-600 text-white transition-colors hover:bg-blue-900"
                  >
                    <Icon class="h-[18px] w-[18px]" />
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="mx-auto flex max-w-[1440px] flex-col items-start justify-between gap-3 px-5 py-6 sm:flex-row sm:items-center lg:px-[120px]">
    <p class="text-sm font-medium text-gray-900">
      Salestime © <span id="footer-year">{year}</span> - Todos os direitos reservados.
    </p>
    <div class="flex items-center gap-2">
      <span class="text-sm text-[#1e1e1e]">Desenvolvido por</span>
      <img src="/images/maatz.svg" alt="Maatz" width="72" height="18" class="h-[18px] w-auto" />
    </div>
  </div>
</footer>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>
