---
import ArrowRight from './icons/ArrowRight.astro';

interface Props {
  id?: string; // âncora do dropdown de serviços do menu
  number: number;
  title: string;
  description: string;
  href?: string;
  active?: boolean; // estado inicial; o carrossel move o destaque via .is-active
}
const { id, number, title, description, href = '#', active = false } = Astro.props;
---
<article
  id={id}
  class:list={[
    'svc-card flex w-[300px] shrink-0 snap-start scroll-mt-28 flex-col gap-12 rounded-3xl p-8 sm:w-[340px] lg:w-[375px]',
    active && 'is-active',
  ]}
>
  <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-lemon text-xl font-bold text-blue-300">
    {number}
  </span>

  <div class="flex flex-col gap-3.5">
    <h3 class="svc-title text-2xl font-semibold leading-[1.3]">{title}</h3>
    <p class="svc-desc text-base font-medium leading-[1.5]">{description}</p>
  </div>

  <a href={href} class="svc-btn btn mt-auto self-start border bg-white py-2.5 pl-6 pr-2.5 text-lg text-blue-600">
    Saiba mais
    <span class="svc-arrow inline-flex size-8 shrink-0 items-center justify-center rounded-full">
      <ArrowRight class="h-[18px] w-[18px]" />
    </span>
  </a>
</article>

<style>
  /* Card ativo (navegação do carrossel) e hover compartilham o mesmo visual navy */
  .svc-card {
    background-color: var(--color-white);
    transition: background-color 0.3s ease;
  }
  .svc-title {
    color: var(--color-blue-900);
    transition: color 0.3s ease;
  }
  .svc-desc {
    color: var(--color-gray-900);
    transition: color 0.3s ease;
  }
  .svc-btn {
    border-color: var(--color-gray-100);
    transition: border-color 0.3s ease;
  }
  .svc-arrow {
    background-color: var(--color-gray-50);
    color: var(--color-blue-600);
    transition: background-color 0.3s ease, color 0.3s ease;
  }
  .svc-card.is-active,
  .svc-card:hover {
    background-color: var(--color-blue-600);
  }
  .svc-card.is-active .svc-title,
  .svc-card:hover .svc-title,
  .svc-card.is-active .svc-desc,
  .svc-card:hover .svc-desc {
    color: var(--color-white);
  }
  .svc-card.is-active .svc-btn,
  .svc-card:hover .svc-btn {
    border-color: var(--color-blue-600);
  }
  .svc-card.is-active .svc-arrow,
  .svc-card:hover .svc-arrow {
    background-color: var(--color-blue-600);
    color: var(--color-white);
  }
</style>
