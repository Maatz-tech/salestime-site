---
import Button from './Button.astro';
import ChevronDown from './icons/ChevronDown.astro';
import MenuIcon from './icons/Menu.astro';
import Close from './icons/Close.astro';
import { mainNav, ctaLabel, ctaHref, services } from '../data/site';

// Link ativo pela rota atual (links de âncora nunca ficam ativos fora da home);
// seções com subpáginas (ex.: /blog/post) mantêm o item pai ativo
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => href === path || (href !== '/' && path.startsWith(`${href}/`));
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-gray-100 bg-gray-50 transition-transform duration-300 will-change-transform"
>
  <div class="mx-auto flex max-w-[1440px] items-center justify-between px-5 py-4 lg:px-[120px]">
    <!-- Logo -->
    <a href="/" class="shrink-0" aria-label="Salestime — início">
      <img
        src="/images/logotipo-salestime.svg"
        alt="Salestime"
        width="164"
        height="33"
        class="h-[30px] w-auto lg:h-[33px]"
      />
    </a>

    <!-- Nav desktop -->
    <nav class="hidden items-center gap-7 lg:flex" aria-label="Principal">
      {mainNav.map((link) =>
        link.hasDropdown ? (
          <div class="relative" data-services-dropdown>
            <button
              type="button"
              aria-expanded="false"
              aria-haspopup="true"
              class="inline-flex cursor-pointer items-center gap-[7px] text-sm font-medium text-gray-900 transition-colors hover:text-blue-600"
            >
              {link.label}
              <ChevronDown class="h-[14px] w-[14px] transition-transform duration-200" />
            </button>
            <div
              class="invisible absolute left-1/2 top-full z-50 mt-4 w-[280px] -translate-x-1/2 translate-y-2 rounded-2xl border border-gray-100 bg-white p-2 opacity-0 shadow-[0px_12px_24px_rgba(10,7,85,0.1)] transition-all duration-200 data-[open]:visible data-[open]:translate-y-0 data-[open]:opacity-100"
              data-services-panel
            >
              {services.map((s) => (
                <a
                  href={`/#${s.slug}`}
                  class="block rounded-xl px-4 py-2.5 text-sm font-medium text-gray-900 transition-colors hover:bg-gray-50 hover:text-blue-600"
                >
                  {s.title}
                </a>
              ))}
              <a
                href="/#servicos"
                class="mt-1 block rounded-xl border-t border-gray-100 px-4 py-2.5 text-sm font-semibold text-blue-600 transition-colors hover:bg-gray-50"
              >
                Ver todos os serviços
              </a>
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class:list={[
              'inline-flex items-center gap-[7px] text-sm transition-colors hover:text-blue-600',
              isActive(link.href) ? 'font-semibold text-blue-600' : 'font-medium text-gray-900',
            ]}
          >
            {link.label}
          </a>
        )
      )}
    </nav>

    <!-- CTA desktop -->
    <div class="hidden lg:block">
      <Button href={ctaHref} variant="primary" size="md">{ctaLabel}</Button>
    </div>

    <!-- Botão mobile -->
    <button
      id="menu-toggle"
      class="text-blue-900 lg:hidden"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <MenuIcon class="h-6 w-6 [.is-open_&]:hidden" />
      <Close class="hidden h-6 w-6 [.is-open_&]:block" />
    </button>
  </div>

  <!-- Menu mobile -->
  <div id="mobile-menu" class="hidden border-t border-gray-100 bg-gray-50 lg:hidden">
    <nav class="mx-auto flex max-w-[1440px] flex-col gap-1 px-5 py-4" aria-label="Mobile">
      {mainNav.map((link) =>
        link.hasDropdown ? (
          <div class="flex flex-col">
            <button
              type="button"
              id="mobile-services-toggle"
              aria-expanded="false"
              aria-controls="mobile-services"
              class="flex w-full cursor-pointer items-center justify-between rounded-lg px-2 py-3 text-base font-medium text-gray-900 transition-colors hover:bg-blue-100/20"
            >
              {link.label}
              <ChevronDown class="h-4 w-4 transition-transform duration-200" />
            </button>
            <div id="mobile-services" class="hidden flex-col gap-1 pb-1 pl-4">
              {services.map((s) => (
                <a
                  href={`/#${s.slug}`}
                  class="rounded-lg px-2 py-2.5 text-base font-medium text-gray-600 transition-colors hover:bg-blue-100/20 hover:text-blue-600"
                >
                  {s.title}
                </a>
              ))}
              <a
                href="/#servicos"
                class="rounded-lg px-2 py-2.5 text-base font-semibold text-blue-600 transition-colors hover:bg-blue-100/20"
              >
                Ver todos os serviços
              </a>
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class:list={[
              'rounded-lg px-2 py-3 text-base transition-colors hover:bg-blue-100/20',
              isActive(link.href) ? 'font-semibold text-blue-600' : 'font-medium text-gray-900',
            ]}
          >
            {link.label}
          </a>
        )
      )}
      <Button href={ctaHref} variant="primary" size="md" class="mt-2 w-full">{ctaLabel}</Button>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector('header');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const open = header?.classList.toggle('is-open');
    menu?.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Fechar menu' : 'Abrir menu');
  });

  // Fecha ao clicar num link
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      header?.classList.remove('is-open');
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    })
  );

  // Dropdown de serviços (desktop): abre no clique, fecha fora/Esc
  const dropdown = document.querySelector<HTMLElement>('[data-services-dropdown]');
  const ddButton = dropdown?.querySelector<HTMLButtonElement>('button');
  const ddPanel = dropdown?.querySelector<HTMLElement>('[data-services-panel]');
  const ddChevron = ddButton?.querySelector<SVGElement>('svg');

  const setDropdown = (open: boolean) => {
    ddPanel?.toggleAttribute('data-open', open);
    ddButton?.setAttribute('aria-expanded', String(open));
    ddChevron?.classList.toggle('rotate-180', open);
  };

  ddButton?.addEventListener('click', () => {
    setDropdown(!ddPanel?.hasAttribute('data-open'));
  });
  document.addEventListener('click', (e) => {
    if (dropdown && !dropdown.contains(e.target as Node)) setDropdown(false);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setDropdown(false);
  });
  ddPanel?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setDropdown(false)));

  // Accordion de serviços (menu mobile)
  const mobServicesToggle = document.getElementById('mobile-services-toggle');
  const mobServices = document.getElementById('mobile-services');
  mobServicesToggle?.addEventListener('click', () => {
    const open = mobServices?.classList.toggle('hidden') === false;
    mobServicesToggle.setAttribute('aria-expanded', String(open));
    mobServicesToggle.querySelector('svg')?.classList.toggle('rotate-180', open);
    mobServices?.classList.toggle('flex', open);
  });

  // Header some ao rolar para baixo, reaparece ao rolar para cima
  let lastY = window.scrollY;
  let ticking = false;
  const onScroll = () => {
    const y = window.scrollY;
    const menuOpen = header?.classList.contains('is-open');
    if (!menuOpen) {
      if (y > lastY && y > 120) {
        header?.classList.add('-translate-y-full');
      } else if (y < lastY) {
        header?.classList.remove('-translate-y-full');
      }
    }
    lastY = y;
    ticking = false;
  };
  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        window.requestAnimationFrame(onScroll);
        ticking = true;
      }
    },
    { passive: true }
  );
</script>
