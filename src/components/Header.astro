---
import Button from './Button.astro';
import ChevronDown from './icons/ChevronDown.astro';
import MenuIcon from './icons/Menu.astro';
import Close from './icons/Close.astro';
import { mainNav, ctaLabel, ctaHref, services } from '../data/site';

// Link ativo pela rota atual (links de âncora nunca ficam ativos fora da home);
// seções com subpáginas (ex.: /blog/post) mantêm o item pai ativo
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => href === path || (href !== '/' && path.startsWith(`${href}/`));
---

<header
  id="site-header"
  class="sticky top-0 z-50 border-b border-gray-100 bg-gray-50 transition-transform duration-300 will-change-transform"
>
  <div class="mx-auto flex max-w-[1440px] items-center justify-between px-5 py-4 lg:px-[120px]">
    <!-- Logo -->
    <a href="/" class="shrink-0" aria-label="Salestime — início">
      <img
        src="/images/logotipo-salestime.svg"
        alt="Salestime"
        width="164"
        height="33"
        class="h-[30px] w-auto lg:h-[33px]"
      />
    </a>

    <!-- Nav desktop -->
    <nav class="hidden items-center gap-7 lg:flex" aria-label="Principal">
      {mainNav.map((link) =>
        link.hasDropdown ? (
          <div class="relative" data-services-dropdown>
            <a
              href={link.href}
              data-services-trigger
              aria-expanded="false"
              aria-haspopup="true"
              class="inline-flex items-center gap-[7px] text-sm font-medium text-gray-900 transition-colors hover:text-blue-600"
            >
              {link.label}
              <ChevronDown class="h-[14px] w-[14px] transition-transform duration-200" />
            </a>
            <div
              class="invisible absolute left-1/2 top-full z-50 mt-4 w-[280px] -translate-x-1/2 translate-y-2 rounded-2xl border border-gray-100 bg-white p-2 opacity-0 shadow-[0px_12px_24px_rgba(10,7,85,0.1)] transition-all duration-200 data-[open]:visible data-[open]:translate-y-0 data-[open]:opacity-100"
              data-services-panel
            >
              {services.map((s) => (
                <a
                  href={s.page ?? `/#${s.slug}`}
                  class="block rounded-xl px-4 py-2.5 text-sm font-medium text-gray-900 transition-colors hover:bg-gray-50 hover:text-blue-600"
                >
                  {s.title}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class:list={[
              'inline-flex items-center gap-[7px] text-sm transition-colors hover:text-blue-600',
              isActive(link.href) ? 'font-semibold text-blue-600' : 'font-medium text-gray-900',
            ]}
          >
            {link.label}
          </a>
        )
      )}
    </nav>

    <!-- CTA desktop -->
    <div class="hidden lg:block">
      <Button href={ctaHref} variant="primary" size="md">{ctaLabel}</Button>
    </div>

    <!-- Botão mobile -->
    <button
      id="menu-toggle"
      class="text-blue-900 lg:hidden"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <MenuIcon class="h-6 w-6" />
    </button>
  </div>
</header>

<!-- Overlay do drawer (mobile) — fora do header por causa do will-change-transform -->
<div
  id="mobile-overlay"
  class="pointer-events-none fixed inset-0 z-[60] bg-blue-900/40 opacity-0 transition-opacity duration-300 lg:hidden"
  aria-hidden="true"
>
</div>

<!-- Drawer (mobile) -->
<aside
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="Menu"
  class="fixed inset-y-0 right-0 z-[70] flex w-[85vw] max-w-[340px] translate-x-full flex-col bg-gray-50 shadow-[-12px_0_32px_rgba(10,7,85,0.18)] transition-transform duration-300 lg:hidden"
>
  <div class="flex items-center justify-between border-b border-gray-100 px-5 py-4">
    <img
      src="/images/logotipo-salestime.svg"
      alt="Salestime"
      width="164"
      height="33"
      class="h-[30px] w-auto"
    />
    <button id="menu-close" class="text-blue-900" aria-label="Fechar menu">
      <Close class="h-6 w-6" />
    </button>
  </div>

  <nav class="flex flex-1 flex-col gap-1 overflow-y-auto px-5 py-4" aria-label="Mobile">
    {mainNav.map((link) =>
      link.hasDropdown ? (
        <div class="flex flex-col">
          <button
            type="button"
            id="mobile-services-toggle"
            aria-expanded="false"
            aria-controls="mobile-services"
            class="flex w-full cursor-pointer items-center justify-between rounded-lg px-2 py-3 text-base font-medium text-gray-900 transition-colors hover:bg-blue-100/20"
          >
            {link.label}
            <ChevronDown class="h-4 w-4 transition-transform duration-200" />
          </button>
          <div id="mobile-services" class="hidden flex-col gap-1 pb-1 pl-4">
            {services.map((s) => (
              <a
                href={s.page ?? `/#${s.slug}`}
                class="rounded-lg px-2 py-2.5 text-base font-medium text-gray-600 transition-colors hover:bg-blue-100/20 hover:text-blue-600"
              >
                {s.title}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a
          href={link.href}
          class:list={[
            'rounded-lg px-2 py-3 text-base transition-colors hover:bg-blue-100/20',
            isActive(link.href) ? 'font-semibold text-blue-600' : 'font-medium text-gray-900',
          ]}
        >
          {link.label}
        </a>
      )
    )}
  </nav>

  <div class="border-t border-gray-100 px-5 py-4">
    <Button href={ctaHref} variant="primary" size="md" class="w-full">{ctaLabel}</Button>
  </div>
</aside>

<script>
  const header = document.querySelector('header');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-overlay');
  const closeBtn = document.getElementById('menu-close');

  // Drawer mobile
  const setDrawer = (open: boolean) => {
    menu?.classList.toggle('translate-x-full', !open);
    overlay?.classList.toggle('opacity-0', !open);
    overlay?.classList.toggle('pointer-events-none', !open);
    toggle?.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  };

  toggle?.addEventListener('click', () => setDrawer(true));
  closeBtn?.addEventListener('click', () => setDrawer(false));
  overlay?.addEventListener('click', () => setDrawer(false));

  // Fecha ao clicar num link
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setDrawer(false)));

  // Dropdown de serviços (desktop): abre no hover/foco, fecha ao sair/Esc
  const dropdown = document.querySelector<HTMLElement>('[data-services-dropdown]');
  const ddTrigger = dropdown?.querySelector<HTMLElement>('[data-services-trigger]');
  const ddPanel = dropdown?.querySelector<HTMLElement>('[data-services-panel]');
  const ddChevron = ddTrigger?.querySelector<SVGElement>('svg');

  const setDropdown = (open: boolean) => {
    ddPanel?.toggleAttribute('data-open', open);
    ddTrigger?.setAttribute('aria-expanded', String(open));
    ddChevron?.classList.toggle('rotate-180', open);
  };

  let closeTimer = 0;
  const openNow = () => {
    window.clearTimeout(closeTimer);
    setDropdown(true);
  };
  // Pequeno atraso para atravessar o vão entre o link e o painel sem fechar
  const closeSoon = () => {
    window.clearTimeout(closeTimer);
    closeTimer = window.setTimeout(() => setDropdown(false), 150);
  };

  dropdown?.addEventListener('mouseenter', openNow);
  dropdown?.addEventListener('mouseleave', closeSoon);
  dropdown?.addEventListener('focusin', openNow);
  dropdown?.addEventListener('focusout', (e) => {
    if (!dropdown.contains(e.relatedTarget as Node)) setDropdown(false);
  });
  ddPanel?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setDropdown(false)));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      setDropdown(false);
      setDrawer(false);
    }
  });

  // Accordion de serviços (drawer mobile)
  const mobServicesToggle = document.getElementById('mobile-services-toggle');
  const mobServices = document.getElementById('mobile-services');
  mobServicesToggle?.addEventListener('click', () => {
    const open = mobServices?.classList.toggle('hidden') === false;
    mobServicesToggle.setAttribute('aria-expanded', String(open));
    mobServicesToggle.querySelector('svg')?.classList.toggle('rotate-180', open);
    mobServices?.classList.toggle('flex', open);
  });

  // Header some ao rolar para baixo, reaparece ao rolar para cima
  let lastY = window.scrollY;
  let ticking = false;
  const onScroll = () => {
    const y = window.scrollY;
    if (y > lastY && y > 120) {
      header?.classList.add('-translate-y-full');
    } else if (y < lastY) {
      header?.classList.remove('-translate-y-full');
    }
    lastY = y;
    ticking = false;
  };
  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        window.requestAnimationFrame(onScroll);
        ticking = true;
      }
    },
    { passive: true }
  );
</script>
