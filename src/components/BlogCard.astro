---
interface Props {
  slug: string;
  title: string;
  summary: string;
  image: string;
  category: string;
  date: string; // já formatada
  author: string;
  authorImage: string;
  class?: string;
  [key: string]: unknown;
}
const {
  slug,
  title,
  summary,
  image,
  category,
  date,
  author,
  authorImage,
  class: className = '',
  ...rest
} = Astro.props;
---
<a
  href={`/blog/${slug}`}
  class:list={[
    'group flex flex-col overflow-hidden rounded-3xl border border-gray-100 bg-white transition-shadow duration-300 hover:shadow-[0px_12px_24px_rgba(10,7,85,0.08)]',
    className,
  ]}
  {...rest}
>
  <div class="overflow-hidden">
    <img
      src={image}
      alt=""
      width="760"
      height="340"
      loading="lazy"
      class="block aspect-[760/340] w-full object-cover transition-transform duration-500 motion-safe:group-hover:scale-[1.03]"
    />
  </div>
  <div class="flex flex-1 flex-col gap-3 p-6">
    <p class="text-xs font-semibold uppercase tracking-[0.04em] text-blue-300">{category}</p>
    <h3 class="text-xl font-semibold leading-[1.3] text-blue-900 transition-colors group-hover:text-blue-600">
      {title}
    </h3>
    <p class="text-sm font-medium leading-[1.6] text-gray-600">{summary}</p>
    <div class="mt-auto flex items-center gap-2.5 pt-3">
      <img
        src={authorImage}
        alt=""
        width="96"
        height="96"
        loading="lazy"
        class="size-8 rounded-full object-cover"
      />
      <span class="text-sm font-semibold text-blue-900">{author}</span>
      <span class="text-sm font-medium text-gray-600">· {date}</span>
    </div>
  </div>
</a>
