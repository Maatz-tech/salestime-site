---
import Button from '../Button.astro';
import ArrowUpRight from '../icons/ArrowUpRight.astro';

const rounded = 'rounded-[14px] rounded-bl-[100px]';
---

<section id="sobre" class="bg-white py-16 lg:py-20">
  <div class="shell flex flex-col items-center gap-14 lg:flex-row lg:justify-between lg:gap-[136px]">
    <!-- Texto + botões: coluna única no desktop; no mobile viram itens soltos (contents) p/ intercalar a foto -->
    <div class="contents lg:flex lg:flex-1 lg:flex-col lg:gap-8">
      <div class="order-1 flex w-full flex-col gap-6 lg:w-auto">
        <p class="eyebrow eyebrow--lg text-blue-300">Conheça a Salestime</p>
        <h2 class="text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[32px]">
          Experiência prática e resultados reais em aceleração comercial
        </h2>
        <div class="flex flex-col gap-4 text-lg font-normal leading-[1.5] text-gray-900">
          <p>
            A Salestime nasceu da insatisfação com modelos tradicionais de
            terceirização e agências que entregam listas frias e reuniões sem
            critério.
          </p>
          <p>
            À frente de estratégias comerciais complexas e combinando a
            experiência acumulada em mais de 200 empresas atendidas, Felipe Traina
            desenvolveu uma metodologia focada na autonomia do cliente.
          </p>
        </div>
      </div>
      <div class="order-3 flex w-full flex-col gap-4 lg:w-auto lg:flex-row">
        <Button
          href="/sobre"
          variant="primary"
          icon
          class="w-full justify-between lg:w-auto lg:justify-center"
        >
          Saiba mais
        </Button>
        <a
          href="https://www.youtube.com/@salestime"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--lg w-full justify-between border border-blue-600 bg-white text-blue-600 hover:bg-blue-600/5 lg:w-auto lg:justify-center"
        >
          Salestime no Youtube
          <ArrowUpRight class="h-[18px] w-[18px]" />
        </a>
      </div>
    </div>

    <!-- Imagem -->
    <div class="relative order-2 w-[320px] shrink-0 sm:w-[380px] lg:order-none">
      <!-- Retângulo decorativo atrás -->
      <div class:list={['absolute -top-6 right-[-24px] h-full w-full bg-blue-600/5', rounded]} aria-hidden="true"></div>

      <!-- Card da foto -->
      <div class:list={['relative aspect-[380/544] overflow-hidden bg-blue-600', rounded]}>
        <img
          src="/images/about/swoosh-lines.svg"
          alt=""
          aria-hidden="true"
          width="458"
          height="437"
          class="pointer-events-none absolute left-1/2 top-3 w-[120%] max-w-none -translate-x-1/2"
        />
        <img
          src="/images/about/felipe.webp"
          alt="Felipe Traina, CEO da Salestime"
          width="760"
          height="1066"
          loading="lazy"
          class="absolute inset-x-0 bottom-0 mx-auto h-full w-full object-cover object-bottom"
        />
      </div>

      <!-- Card do nome -->
      <div class="absolute bottom-10 right-[-16px] rounded-xl bg-white px-6 py-4 shadow-[0px_12px_9px_rgba(0,0,0,0.1),0px_2px_2px_rgba(0,0,0,0.07)]">
        <p class="text-xl font-semibold text-blue-900">Felipe Traina</p>
        <p class="text-base font-normal text-gray-900">CEO Salestime</p>
      </div>
    </div>
  </div>
</section>
