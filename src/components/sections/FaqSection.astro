---
import Button from '../Button.astro';

const faqs = [
  {
    q: 'Quanto tempo leva para implementar a metodologia?',
    a: 'O tempo varia conforme a maturidade da sua operação, mas a maioria dos clientes começa a ver os primeiros resultados entre 30 e 90 dias após o início da implementação.',
  },
  {
    q: 'A Salestime substitui meu time comercial?',
    a: 'Não. Nós estruturamos, treinamos e damos autonomia ao seu time — atuamos como parceiros estratégicos, e não como substitutos da sua equipe.',
  },
  {
    q: 'A metodologia funciona para qualquer empresa?',
    a: 'Nossa metodologia é validada para empresas B2B de diferentes segmentos. No diagnóstico avaliamos o seu contexto para adaptar a estratégia à sua realidade.',
  },
  {
    q: 'Vocês ajudam na implementação do CRM?',
    a: 'Sim. Implementamos e configuramos o CRM com automações, dashboards e indicadores para dar visibilidade e controle à sua operação comercial.',
  },
  {
    q: 'Após a implementação terei suporte da Salestime?',
    a: 'Sim. Oferecemos acompanhamento contínuo para garantir que a metodologia seja mantida e evolua junto com a sua operação.',
  },
];
---

<section id="faq" class="relative overflow-hidden bg-white py-16 lg:py-20">
  <!-- Grade decorativa (sutil, canto superior esquerdo) -->
  <div
    class="pointer-events-none absolute -left-40 -top-60 hidden h-[924px] w-[1231px] opacity-50 lg:block"
    style="
      background-image:
        linear-gradient(to right, rgba(208,213,221,.3) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(208,213,221,.3) 1px, transparent 1px);
      background-size: 61px 61px;
      -webkit-mask-image: radial-gradient(circle at 40% 70%, black, transparent 65%);
      mask-image: radial-gradient(circle at 40% 70%, black, transparent 65%);
    "
    aria-hidden="true"
  >
  </div>

  <div class="shell relative flex flex-col gap-12 lg:flex-row lg:justify-between lg:gap-16">
    <!-- Intro -->
    <div class="flex flex-col gap-7 lg:w-[384px]">
      <div class="flex flex-col gap-3.5">
        <p class="eyebrow eyebrow--lg text-blue-300">FAQ</p>
        <h2 class="text-[24px] font-semibold leading-[1.3] text-blue-900 lg:text-[32px]">
          Perguntas frequentes
        </h2>
        <p class="text-lg font-normal leading-[1.5] text-gray-900">
          Não encontrou a resposta? Nossa equipe está pronta para esclarecer suas
          dúvidas sobre nossos serviços.
        </p>
      </div>
      <Button href="#contato" variant="outline" size="lg" class="self-start border-blue-600 text-blue-600">
        Fale conosco
      </Button>
    </div>

    <!-- Accordion -->
    <div class="flex flex-col gap-6 lg:w-[592px]">
      {faqs.map((item) => (
        <details class="group border-b border-gray-100 pb-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 [&::-webkit-details-marker]:hidden">
            <span class="text-lg font-semibold leading-[1.3] text-blue-900 transition-colors group-hover:text-blue-600">{item.q}</span>
            <span class="relative flex size-8 shrink-0 items-center justify-center rounded-full text-blue-600 transition-transform duration-300 group-open:rotate-180">
              <span class="absolute h-[2px] w-[14px] rounded bg-current"></span>
              <span class="absolute h-[14px] w-[2px] rounded bg-current transition-transform duration-300 group-open:scale-y-0"></span>
            </span>
          </summary>
          <div class="faq-content h-0 overflow-hidden">
            <p class="pt-4 text-base font-normal leading-[1.6] text-gray-600">{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script>
  // Accordion do FAQ: anima a altura na abertura/fechamento.
  // O expand é discreto e acionado por clique, então roda mesmo com "reduzir movimento".
  document.querySelectorAll<HTMLDetailsElement>('#faq details').forEach((d) => {
    const summary = d.querySelector('summary');
    const content = d.querySelector<HTMLElement>('.faq-content');
    if (!summary || !content) return;
    content.style.transition = 'height 0.3s ease';

    summary.addEventListener('click', (e) => {
      e.preventDefault();
      if (content.dataset.animating) return;

      if (d.open) {
        content.dataset.animating = '1';
        content.style.height = content.scrollHeight + 'px';
        requestAnimationFrame(() => (content.style.height = '0px'));
        content.addEventListener(
          'transitionend',
          () => {
            d.open = false;
            content.style.height = '0px';
            delete content.dataset.animating;
          },
          { once: true }
        );
      } else {
        d.open = true;
        const target = content.scrollHeight;
        content.style.height = '0px';
        requestAnimationFrame(() => (content.style.height = target + 'px'));
        content.addEventListener(
          'transitionend',
          () => (content.style.height = 'auto'),
          { once: true }
        );
      }
    });
  });
</script>
