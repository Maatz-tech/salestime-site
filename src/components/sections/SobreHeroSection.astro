---
---

<section class="relative overflow-hidden bg-gray-50">
  <!-- Grade decorativa (sutil, à direita) -->
  <div
    class="pointer-events-none absolute inset-y-0 right-0 hidden w-1/2 opacity-60 lg:block"
    style="
      background-image:
        linear-gradient(to right, rgba(208,213,221,.35) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(208,213,221,.35) 1px, transparent 1px);
      background-size: 61px 61px;
      -webkit-mask-image: radial-gradient(circle at 70% 80%, black, transparent 70%);
      mask-image: radial-gradient(circle at 70% 80%, black, transparent 70%);
    "
    aria-hidden="true"
  >
  </div>

  <!-- Swoosh decorativo no topo direito -->
  <img
    src="/images/sobre/hero-swoosh.svg"
    alt=""
    aria-hidden="true"
    width="790"
    height="753"
    class="pointer-events-none absolute right-0 top-[-176px] hidden w-[790px] max-w-none lg:block"
  />

  <div class="shell relative flex flex-col gap-5 py-14 lg:items-center lg:py-[115px] lg:text-center">
    <div class="flex items-center gap-3">
      <img
        src="/images/sobre/eyebrow-icon.svg"
        alt=""
        aria-hidden="true"
        width="24"
        height="22"
        class="h-[22px] w-6"
      />
      <p class="eyebrow eyebrow--lg text-blue-300">Sobre nós</p>
    </div>
    <h1 class="h1 max-w-[926px]">
      Um time apaixonado por impulsionar as vendas do seu negócio
    </h1>
  </div>
</section>
