---
const inputBase =
  'w-full h-[53px] rounded-lg border border-gray-100 bg-white px-4 text-base text-blue-900 placeholder:text-blue-900/60 transition-colors focus:border-blue-300 focus:outline-none';
---

<section class="bg-white py-16 lg:py-20">
  <div class="shell">
    <div data-card class="relative flex flex-col items-center gap-8 rounded-3xl bg-gray-50 lg:mt-16 lg:flex-row lg:items-stretch lg:gap-10">
      <!-- Imagem: caixa azul com 100% da altura da coluna, encostada; cabeça vaza por cima (oculta no mobile, como no Figma) -->
      <div class="relative hidden h-[290px] w-[240px] shrink-0 lg:block">
        <!-- Caixa azul (altura total) -->
        <div class="absolute inset-0 rounded-3xl bg-blue-600"></div>
        <!-- Recorte da pessoa: largura = caixa (sem cortar lados), altura natural, cabeça vaza -->
        <div class="absolute inset-x-0 bottom-0 top-[-120px] overflow-hidden rounded-b-3xl">
          <img
            src="/images/newsletter/person.webp"
            alt="Assinante da newsletter da Salestime"
            width="392"
            height="668"
            loading="lazy"
            class="absolute bottom-0 left-0 w-full max-w-none"
          />
        </div>
        <!-- Pill Salestime -->
        <div class="absolute bottom-4 left-1/2 z-20 -translate-x-1/2 rounded-full bg-white px-3 py-2 shadow-[0px_6px_5px_rgba(0,0,0,0.1),0px_1px_1px_rgba(0,0,0,0.07)]">
          <img src="/images/logotipo-salestime.svg" alt="Salestime" width="90" height="18" class="h-[18px] w-auto" />
        </div>
      </div>

      <!-- Texto + form -->
      <div class="flex w-full flex-col justify-center gap-8 px-6 py-10 sm:px-10 lg:pl-0 lg:pr-12">
        <div class="flex flex-col gap-4 text-left">
          <h2 class="text-2xl font-semibold leading-[1.3] text-blue-900">
            Conteúdos exclusivos por e-mail
          </h2>
          <p class="text-lg font-normal leading-[1.5] text-gray-900">
            Assine nossa newsletter e receba conteúdos, dicas e novidades diariamente.
          </p>
        </div>

        <form class="flex flex-col items-end gap-5 sm:flex-row" action="#" method="post" data-form="newsletter">
          <!-- TODO: definir endpoint real da newsletter antes do deploy -->
          <div class="flex w-full flex-col gap-3">
            <label for="news-nome" class="text-base text-blue-900">Nome <span class="text-[#ea4335]">*</span></label>
            <input id="news-nome" name="nome" type="text" required autocomplete="name" class={inputBase} />
          </div>
          <div class="flex w-full flex-col gap-3">
            <label for="news-email" class="text-base text-blue-900">E-mail <span class="text-[#ea4335]">*</span></label>
            <input id="news-email" name="email" type="email" required autocomplete="email" placeholder="Digite seu e-mail" class={inputBase} />
          </div>
          <button type="submit" class="btn btn--primary h-[53px] w-full shrink-0 px-8 sm:w-auto">
            Cadastrar
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
