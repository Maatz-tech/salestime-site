---
import ArrowLink from '../ArrowLink.astro';
import { ctaHref } from '../../data/site';
---

<section class="border-t border-gray-50 bg-white py-16 lg:py-20">
  <div class="shell flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between lg:gap-16">
    <!-- Heading -->
    <div class="flex flex-col gap-3">
      <span class="h-1.5 w-10 rounded-full bg-blue-300" aria-hidden="true"></span>
      <h2 class="max-w-[493px] text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[32px]">
        Sabemos que pode ser difícil identificar os gargalos de uma operação comercial
      </h2>
    </div>

    <!-- Texto + link -->
    <div class="flex max-w-[479px] flex-col gap-3.5">
      <p class="body-lg">
        Para isso foi criada nossa metodologia. Somos especialistas em estruturar
        operações mais previsíveis, eficientes e orientadas por dados.
      </p>
      <ArrowLink href={ctaHref} class="self-start">Solicite um diagnóstico</ArrowLink>
    </div>
  </div>
</section>
