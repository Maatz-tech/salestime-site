---
import Button from '../../Button.astro';
import { ctaHref } from '../../../data/site';

interface Challenge {
  icon: string; // caminho do svg em /public
  label: string;
}
interface Props {
  title?: string;
  description: string;
  challenges: Challenge[];
}
const {
  title = 'Sua empresa enfrenta algum destes desafios?',
  description,
  challenges,
} = Astro.props;
---

<section id="quando-contratar" class="bg-white py-16 lg:py-20">
  <div class="shell flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-20">
    <!-- Intro -->
    <div class="flex flex-col gap-4 lg:w-[420px] lg:shrink-0 lg:gap-10">
      <div class="flex flex-col gap-4">
        <p class="eyebrow eyebrow--lg text-blue-300">Quando contratar</p>
        <h2 class="text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[36px]">
          {title}
        </h2>
        <p class="text-lg font-normal leading-[1.5] text-gray-900">{description}</p>
      </div>
      <Button href={ctaHref} variant="primary" icon class="hidden self-start lg:inline-flex">
        Faça um diagnóstico
      </Button>
    </div>

    <!-- Desafios -->
    <div class="grid min-w-0 flex-1 gap-4 sm:grid-cols-2">
      {challenges.map((c) => (
        <div class="flex items-center gap-4 rounded-2xl border border-transparent bg-gray-50 p-6 transition-colors hover:border-blue-300">
          <img src={c.icon} alt="" width="24" height="24" class="h-6 w-6 shrink-0" />
          <p class="text-lg font-semibold leading-[1.3] text-blue-900">{c.label}</p>
        </div>
      ))}
    </div>

    <Button href={ctaHref} variant="primary" icon class="w-full justify-between lg:hidden">
      Faça um diagnóstico
    </Button>
  </div>
</section>
