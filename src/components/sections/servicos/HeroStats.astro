---
// Arte de hero das páginas de serviço: foto + cards flutuantes de resultados
interface Props {
  image: string;
  alt: string;
}
const { image, alt } = Astro.props;
const meses = ['Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'];
---

<div data-card class="relative mx-auto w-full max-w-[568px] pb-10 pt-8 lg:pb-0 lg:pt-0">
  <div class="relative lg:ml-[63px] lg:mt-[15px] lg:h-[350px] lg:w-[460px]">
    <img
      src={image}
      alt={alt}
      width="920"
      height="700"
      fetchpriority="high"
      class="block aspect-[460/350] w-full rounded-3xl border border-gray-100 object-cover"
    />
  </div>

  <!-- Card: faturamento do mês -->
  <div class="absolute left-0 top-0 rounded-2xl bg-blue-300/10 p-3 lg:left-[25px] lg:top-[-15px]">
    <div class="flex flex-col gap-2 rounded-lg border border-gray-100 bg-white p-3.5">
      <div class="flex items-center gap-1.5">
        <span class="text-xs font-medium text-gray-900">Este mês</span>
        <span class="rounded-full bg-lemon px-1.5 py-0.5 text-[8px] font-semibold text-blue-300">↑ 15%</span>
      </div>
      <span class="text-base font-bold text-blue-900">R$ 34.000</span>
    </div>
  </div>

  <!-- Card: leads (some no mobile, como no Figma) -->
  <div class="absolute right-0 top-[40px] hidden rounded-2xl bg-blue-300/10 p-3 sm:block lg:right-[-68px] lg:top-[40px]">
    <div class="flex items-center gap-3 rounded-lg border border-gray-100 bg-white p-3.5">
      <span class="flex size-8 items-center justify-center rounded-md bg-lemon text-blue-600">
        <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 21a8 8 0 0 0-16 0" /><circle cx="10" cy="8" r="5" /><path d="M22 20c0-3.37-2-6.5-4-8a5 5 0 0 0-.45-8.3" />
        </svg>
      </span>
      <div class="flex flex-col gap-1">
        <span class="text-xs font-medium text-gray-900">Leads</span>
        <span class="text-base font-bold text-blue-900">+168</span>
      </div>
    </div>
  </div>

  <!-- Card: mini gráfico -->
  <div class="absolute bottom-0 right-0 rounded-2xl bg-blue-300/10 p-3 lg:bottom-[-16px] lg:left-0 lg:right-auto">
    <div class="flex w-[200px] flex-col gap-1 rounded-lg bg-white p-3">
      <svg viewBox="0 0 176 78" class="h-[78px] w-full" aria-hidden="true">
        <defs>
          <linearGradient id="chart-fill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#332ade" stop-opacity="0.45" />
            <stop offset="100%" stop-color="#332ade" stop-opacity="0" />
          </linearGradient>
        </defs>
        {[0, 1, 2, 3].map((i) => (
          <line x1="0" y1={10 + i * 19} x2="176" y2={10 + i * 19} stroke="#e4e4e7" stroke-width="0.6" />
        ))}
        <path
          d="M0 62 C 14 50, 24 44, 36 50 C 48 56, 56 62, 68 56 C 80 50, 86 30, 100 28 C 112 26, 118 38, 130 34 C 144 29, 150 14, 162 10 L 176 6 L 176 78 L 0 78 Z"
          fill="url(#chart-fill)"
        />
        <path
          d="M0 62 C 14 50, 24 44, 36 50 C 48 56, 56 62, 68 56 C 80 50, 86 30, 100 28 C 112 26, 118 38, 130 34 C 144 29, 150 14, 162 10 L 176 6"
          fill="none"
          stroke="#332ade"
          stroke-width="1.6"
        />
      </svg>
      <div class="flex justify-between px-0.5">
        {meses.map((m) => (
          <span class="text-[8px] font-normal text-gray-900 opacity-50">{m}</span>
        ))}
      </div>
    </div>
  </div>
</div>
