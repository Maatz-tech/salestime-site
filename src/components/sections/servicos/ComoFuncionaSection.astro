---
import ArrowLeft from '../../icons/ArrowLeft.astro';
import ArrowRight from '../../icons/ArrowRight.astro';

interface Step {
  icon: string; // caminho do svg em /public
  title: string;
  body: string;
}
interface Props {
  title?: string;
  steps: Step[];
}
const { title = 'Um caminho claro para transformar seus resultados', steps } = Astro.props;
---

<section id="como-funciona" class="bg-gray-50 py-16 lg:py-20" data-cf>
  <div class="shell flex flex-col gap-8 lg:gap-12">
    <!-- Cabeçalho + setas -->
    <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
      <div class="flex flex-col gap-4">
        <p class="eyebrow eyebrow--lg text-blue-300">Como funciona</p>
        <h2 class="text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[32px]">
          {title}
        </h2>
      </div>
      <div class="flex items-center gap-4">
        <button
          type="button"
          data-cf-prev
          aria-label="Etapa anterior"
          class="flex size-10 items-center justify-center rounded-full bg-blue-600 text-white transition-opacity disabled:cursor-default disabled:opacity-20"
        >
          <ArrowLeft class="h-6 w-6" />
        </button>
        <button
          type="button"
          data-cf-next
          aria-label="Próxima etapa"
          class="flex size-10 items-center justify-center rounded-full bg-blue-600 text-white transition-opacity disabled:cursor-default disabled:opacity-20"
        >
          <ArrowRight class="h-6 w-6" />
        </button>
      </div>
    </div>

    <!-- Carrossel: no desktop os cards vazam até a borda direita da viewport -->
    <div class="min-w-0 lg:mr-[calc((min(1200px,100vw)-100vw)/2)]">
      <ul
        data-cf-track
        data-carousel-track
        class="-mx-5 flex snap-x snap-mandatory items-stretch gap-9 overflow-x-auto scroll-pl-5 px-5 [scrollbar-width:none] lg:mx-0 lg:gap-8 lg:scroll-pl-0 lg:px-0 [&::-webkit-scrollbar]:hidden"
      >
        {steps.map((step, i) => (
          <li class="flex w-[calc(100vw-76px)] max-w-[375px] shrink-0 snap-start lg:w-[375px]">
            <article class:list={['cf-card flex w-full flex-col gap-10 rounded-3xl p-8', i === 0 && 'is-active']}>
              <span class="flex size-11 items-center justify-center rounded-full bg-lemon" aria-hidden="true">
                <img src={step.icon} alt="" width="20" height="20" class="h-5 w-5" />
              </span>
              <div class="flex flex-col gap-3.5">
                <h3 class="cf-title text-2xl font-semibold leading-[1.3]">{i + 1}. {step.title}</h3>
                <p class="cf-body text-base font-medium leading-[1.5]">{step.body}</p>
              </div>
            </article>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .cf-card {
    background-color: var(--color-white);
    transition: background-color 0.3s ease;
  }
  .cf-card .cf-title {
    color: var(--color-blue-900);
    transition: color 0.3s ease;
  }
  .cf-card .cf-body {
    color: var(--color-gray-900);
    transition: color 0.3s ease;
  }
  .cf-card.is-active,
  .cf-card:hover {
    background-color: var(--color-blue-600);
  }
  .cf-card.is-active .cf-title,
  .cf-card.is-active .cf-body,
  .cf-card:hover .cf-title,
  .cf-card:hover .cf-body {
    color: var(--color-white);
  }
  /* Hover em outro card "rouba" o destaque: o ativo aparece inativo */
  [data-cf-track]:has(.cf-card:hover) .cf-card.is-active:not(:hover) {
    background-color: var(--color-white);
  }
  [data-cf-track]:has(.cf-card:hover) .cf-card.is-active:not(:hover) .cf-title {
    color: var(--color-blue-900);
  }
  [data-cf-track]:has(.cf-card:hover) .cf-card.is-active:not(:hover) .cf-body {
    color: var(--color-gray-900);
  }
</style>

<script>
  import { initCarousel } from '../../../scripts/carousel';

  document.querySelectorAll<HTMLElement>('[data-cf]').forEach((root) => {
    const track = root.querySelector<HTMLElement>('[data-cf-track]');
    const prev = root.querySelector<HTMLButtonElement>('[data-cf-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-cf-next]');
    if (!track || !prev || !next) return;
    initCarousel({
      track,
      prev,
      next,
      cards: [...track.querySelectorAll<HTMLElement>('.cf-card')],
    });
  });
</script>
