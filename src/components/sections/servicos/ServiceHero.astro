---
import Button from '../../Button.astro';
import EyebrowBadge from '../../EyebrowBadge.astro';
import { ctaHref } from '../../../data/site';

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  ctaLabel?: string;
}
const { eyebrow, title, description, ctaLabel = 'Faça um diagnóstico' } = Astro.props;
---

<section class="relative overflow-hidden bg-gray-50">
  <!-- Grade decorativa (sutil, à direita) -->
  <div
    class="pointer-events-none absolute inset-y-0 right-0 hidden w-1/2 opacity-60 lg:block"
    style="
      background-image:
        linear-gradient(to right, rgba(208,213,221,.35) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(208,213,221,.35) 1px, transparent 1px);
      background-size: 61px 61px;
      -webkit-mask-image: radial-gradient(circle at 60% 55%, black, transparent 70%);
      mask-image: radial-gradient(circle at 60% 55%, black, transparent 70%);
    "
    aria-hidden="true"
  >
  </div>

  <div class="shell relative grid items-center gap-12 py-12 lg:grid-cols-2 lg:gap-10 lg:py-[100px]">
    <!-- Conteúdo -->
    <div class="flex flex-col items-start gap-8 lg:max-w-[488px]">
      <div class="flex flex-col gap-5">
        <div class="flex items-center gap-3">
          <EyebrowBadge tone="brand" />
          <p class="eyebrow eyebrow--lg text-blue-300">{eyebrow}</p>
        </div>
        <div class="flex flex-col gap-3.5">
          <h1 class="text-[28px] font-semibold leading-[1.3] text-blue-900 lg:text-[48px]">{title}</h1>
          <p class="text-lg font-medium leading-[1.5] text-gray-900">{description}</p>
        </div>
      </div>
      <Button href={ctaHref} variant="primary" icon>{ctaLabel}</Button>
    </div>

    <!-- Arte do serviço -->
    <slot name="visual" />
  </div>
</section>
