---
import Button from '../../Button.astro';
import { ctaHref } from '../../../data/site';

interface Item {
  icon: string;
  title: string;
  body: string;
}
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  items: Item[];
  ctaLabel?: string;
}
const { eyebrow, title, description, items, ctaLabel = 'Fale com um especialista' } = Astro.props;
---

<section id="quando-contratar" class="bg-white py-16 lg:py-20">
  <div class="shell flex flex-col gap-10 lg:items-center lg:gap-16">
    <div class="flex flex-col gap-4 lg:items-center lg:text-center">
      <p class="eyebrow eyebrow--lg text-blue-300">{eyebrow}</p>
      <h2 class="max-w-[900px] text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[36px]">
        {title}
      </h2>
      <p class="max-w-[760px] text-lg font-normal leading-[1.5] text-gray-900">{description}</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8">
      {items.map((item) => (
        <div class="flex flex-col gap-6 rounded-3xl p-6 transition-colors hover:bg-gray-50">
          <span class="flex size-12 items-center justify-center rounded-full bg-blue-300" aria-hidden="true">
            <img src={item.icon} alt="" width="24" height="24" class="h-6 w-6" />
          </span>
          <div class="flex flex-col gap-3.5">
            <h3 class="text-2xl font-semibold leading-[1.3] text-blue-900">{item.title}</h3>
            <p class="text-base font-medium leading-[1.5] text-gray-900">{item.body}</p>
          </div>
        </div>
      ))}
    </div>

    <Button href={ctaHref} variant="primary" icon class="self-center">
      {ctaLabel}
    </Button>
  </div>
</section>
