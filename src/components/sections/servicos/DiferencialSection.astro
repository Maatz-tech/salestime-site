---
interface Item {
  icon: string;
  title: string;
  body: string;
}
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  image: string;
  imageAlt?: string;
  items: Item[];
}
const { eyebrow, title, description, image, imageAlt = '', items } = Astro.props;
---

<section id="diferencial" class="bg-gray-50 py-16 lg:py-20">
  <div class="shell flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-20">
    <!-- Intro + imagem -->
    <div class="flex min-w-0 flex-1 flex-col gap-10">
      <div class="flex flex-col gap-4">
        <p class="eyebrow eyebrow--lg text-blue-300">{eyebrow}</p>
        <h2 class="text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[36px]">{title}</h2>
        <p class="text-lg font-normal leading-[1.5] text-gray-900">{description}</p>
      </div>
      <div data-card class="relative hidden w-full max-w-[549px] overflow-hidden rounded-3xl lg:block">
        <img
          src={image}
          alt={imageAlt}
          width="1098"
          height="624"
          loading="lazy"
          class="block aspect-[549/312] w-full object-cover"
        />
        <div
          class="absolute inset-0"
          style="background-image: linear-gradient(75.7deg, rgba(51,42,222,0.6) 1.5%, rgba(51,42,222,0) 43.2%)"
          aria-hidden="true"
        >
        </div>
      </div>
    </div>

    <!-- Diferenciais -->
    <div class="flex min-w-0 flex-1 flex-col gap-6">
      {items.map((item, i) => (
        <div class:list={['flex flex-col gap-4 rounded-3xl p-8', i === 0 ? 'bg-blue-600' : 'bg-white']}>
          <div class="flex items-center gap-3.5">
            <img src={item.icon} alt="" width="24" height="24" class="h-6 w-6 shrink-0" />
            <h3 class:list={['text-xl font-semibold leading-[1.3] lg:text-2xl', i === 0 ? 'text-white' : 'text-blue-900']}>
              {item.title}
            </h3>
          </div>
          <p class:list={['text-base font-normal leading-[1.5]', i === 0 ? 'text-white' : 'text-gray-900']}>
            {item.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
