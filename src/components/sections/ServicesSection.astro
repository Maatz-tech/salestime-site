---
import ServiceCard from '../ServiceCard.astro';
import ArrowLeft from '../icons/ArrowLeft.astro';
import ArrowRight from '../icons/ArrowRight.astro';

const services = [
  {
    number: 1,
    title: 'Estratégia comercial',
    description:
      'Método completo para estruturar, acelerar e escalar sua operação comercial com estratégia, tecnologia e execução assistida.',
  },
  {
    number: 2,
    title: 'Consultoria de Vendas',
    description:
      'Análise estratégica para corrigir gargalos, aumentar conversões e criar previsibilidade no funil de vendas.',
  },
  {
    number: 3,
    title: 'Terceirização de SDR/BDR',
    description:
      'Nossa equipe executa a prospecção utilizando processos validados para gerar oportunidades alinhadas ao seu ICP.',
  },
  {
    number: 4,
    title: 'Implementação de CRM',
    description:
      'Configuramos automações, dashboards e indicadores para que sua equipe tenha controle e capacidade de tomar decisões baseadas em dados.',
  },
];
---

<section id="servicos" class="bg-gray-50 py-16 lg:py-20">
  <div class="shell flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-10">
    <!-- Cabeçalho + controles -->
    <div class="flex shrink-0 flex-col gap-6 lg:w-[385px]">
      <p class="eyebrow eyebrow--lg text-blue-300">Serviços</p>
      <div class="flex flex-col gap-4">
        <h2 class="text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[32px]">
          Como ajudamos a sua empresa
        </h2>
        <p class="text-base font-normal leading-[1.5] text-gray-900">
          Vá além com a Salestime: oferecemos todos os serviços necessários para
          impulsionar suas vendas.
        </p>
      </div>
      <div class="flex items-center gap-4">
        <button
          type="button"
          data-carousel-prev
          aria-label="Serviço anterior"
          class="flex size-10 items-center justify-center rounded-full bg-blue-600 text-white opacity-20 transition-opacity enabled:hover:opacity-100 disabled:cursor-not-allowed"
        >
          <ArrowLeft class="h-6 w-6" />
        </button>
        <button
          type="button"
          data-carousel-next
          aria-label="Próximo serviço"
          class="flex size-10 items-center justify-center rounded-full bg-blue-600 text-white transition-opacity hover:opacity-90 disabled:opacity-20"
        >
          <ArrowRight class="h-6 w-6" />
        </button>
      </div>
    </div>

    <!-- Carrossel -->
    <div
      data-carousel-track
      class="-mx-5 flex min-w-0 flex-1 cursor-grab gap-[31px] overflow-x-auto px-5 pb-2 select-none active:cursor-grabbing [scrollbar-width:none] [&::-webkit-scrollbar]:hidden lg:mx-0 lg:px-0"
    >
      {services.map((s, i) => (
        <ServiceCard number={s.number} title={s.title} description={s.description} active={i === 0} />
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('#servicos').forEach((section) => {
    const track = section.querySelector<HTMLElement>('[data-carousel-track]');
    const prev = section.querySelector<HTMLButtonElement>('[data-carousel-prev]');
    const next = section.querySelector<HTMLButtonElement>('[data-carousel-next]');
    if (!track || !prev || !next) return;

    const step = () => {
      const card = track.querySelector<HTMLElement>('article');
      const gap = parseFloat(getComputedStyle(track).columnGap || '31') || 31;
      return (card?.offsetWidth ?? 375) + gap;
    };

    const FADE = 64; // px de esvaecimento nas bordas
    const update = () => {
      const max = track.scrollWidth - track.clientWidth - 1;
      const atStart = track.scrollLeft <= 0;
      const atEnd = track.scrollLeft >= max;
      prev.disabled = atStart;
      next.disabled = atEnd;

      // Fade nas bordas só no desktop; no mobile o track sangra até 100vw (sem fade)
      const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
      if (isDesktop) {
        const left = atStart ? 0 : FADE;
        const right = atEnd ? 0 : FADE;
        const mask = `linear-gradient(to right, transparent 0, #000 ${left}px, #000 calc(100% - ${right}px), transparent 100%)`;
        track.style.webkitMaskImage = mask;
        track.style.maskImage = mask;
      } else {
        track.style.webkitMaskImage = 'none';
        track.style.maskImage = 'none';
      }
    };

    prev.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
    next.addEventListener('click', () => track.scrollBy({ left: step(), behavior: 'smooth' }));
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();

    // Arrastar com o mouse
    let dragging = false;
    let startX = 0;
    let startScroll = 0;
    let moved = false;
    track.addEventListener('pointerdown', (e) => {
      dragging = true;
      moved = false;
      startX = e.pageX;
      startScroll = track.scrollLeft;
      track.setPointerCapture(e.pointerId);
    });
    track.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const delta = e.pageX - startX;
      if (Math.abs(delta) > 3) moved = true;
      track.scrollLeft = startScroll - delta;
    });
    const endDrag = (e: PointerEvent) => {
      if (!dragging) return;
      dragging = false;
      try {
        track.releasePointerCapture(e.pointerId);
      } catch {}
      update();
    };
    track.addEventListener('pointerup', endDrag);
    track.addEventListener('pointercancel', endDrag);
    // Não segue o link "Saiba mais" ao arrastar
    track.addEventListener('click', (e) => {
      if (moved) {
        e.preventDefault();
        e.stopPropagation();
      }
    }, true);
  });
</script>
