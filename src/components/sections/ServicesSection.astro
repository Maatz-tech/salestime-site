---
import ServiceCard from '../ServiceCard.astro';
import ArrowLeft from '../icons/ArrowLeft.astro';
import ArrowRight from '../icons/ArrowRight.astro';
import { services } from '../../data/site';
---

<section id="servicos" class="bg-gray-50 py-16 lg:py-20">
  <div class="shell flex flex-col gap-10 lg:flex-row lg:items-start lg:gap-10">
    <!-- Cabeçalho + controles -->
    <div class="flex shrink-0 flex-col gap-6 lg:w-[385px]">
      <p class="eyebrow eyebrow--lg text-blue-300">Serviços</p>
      <div class="flex flex-col gap-4">
        <h2 class="text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[32px]">
          Como ajudamos a sua empresa
        </h2>
        <p class="text-base font-normal leading-[1.5] text-gray-900">
          Vá além com a Salestime: oferecemos todos os serviços necessários para
          impulsionar suas vendas.
        </p>
      </div>
      <div class="flex items-center gap-4">
        <button
          type="button"
          data-carousel-prev
          aria-label="Serviço anterior"
          class="flex size-10 items-center justify-center rounded-full bg-blue-600 text-white transition-opacity disabled:cursor-default disabled:opacity-20"
        >
          <ArrowLeft class="h-6 w-6" />
        </button>
        <button
          type="button"
          data-carousel-next
          aria-label="Próximo serviço"
          class="flex size-10 items-center justify-center rounded-full bg-blue-600 text-white transition-opacity disabled:cursor-default disabled:opacity-20"
        >
          <ArrowRight class="h-6 w-6" />
        </button>
      </div>
    </div>

    <!-- Carrossel -->
    <div
      data-carousel-track
      class="-mx-5 flex min-w-0 flex-1 cursor-grab snap-x snap-mandatory gap-[31px] overflow-x-auto scroll-pl-5 px-5 pb-2 select-none active:cursor-grabbing [scrollbar-width:none] [&::-webkit-scrollbar]:hidden lg:mx-0 lg:scroll-pl-0 lg:px-0"
    >
      {services.map((s, i) => (
        <ServiceCard id={s.slug} number={i + 1} title={s.title} description={s.description} active={i === 0} />
      ))}
    </div>
  </div>
</section>

<script>
  import { initCarousel } from '../../scripts/carousel';

  document.querySelectorAll<HTMLElement>('#servicos').forEach((section) => {
    const track = section.querySelector<HTMLElement>('[data-carousel-track]');
    const prev = section.querySelector<HTMLButtonElement>('[data-carousel-prev]');
    const next = section.querySelector<HTMLButtonElement>('[data-carousel-next]');
    if (!track || !prev || !next) return;

    const cards = [...track.querySelectorAll<HTMLElement>('article')];
    const carousel = initCarousel({ track, prev, next, cards });

    // Âncora vinda do menu (/#slug-do-servico): destaca o card correspondente.
    // O goTo espera o scroll nativo da âncora terminar para não ser atropelado.
    const jumpToHash = () => {
      const idx = cards.findIndex((c) => c.id && c.id === location.hash.slice(1));
      if (idx >= 0) setTimeout(() => carousel.goTo(idx), 400);
    };
    window.addEventListener('hashchange', jumpToHash);
    jumpToHash();

    // Arrastar com o mouse
    let dragging = false;
    let startX = 0;
    let startScroll = 0;
    let moved = false;
    track.addEventListener('pointerdown', (e) => {
      dragging = true;
      moved = false;
      startX = e.pageX;
      startScroll = track.scrollLeft;
      track.setPointerCapture(e.pointerId);
    });
    track.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const delta = e.pageX - startX;
      if (Math.abs(delta) > 3) moved = true;
      track.scrollLeft = startScroll - delta;
    });
    const endDrag = (e: PointerEvent) => {
      if (!dragging) return;
      dragging = false;
      try {
        track.releasePointerCapture(e.pointerId);
      } catch {}
      // Arraste via JS não dispara o scroll-snap nativo; encaixa no card mais próximo
      if (moved) carousel.goTo(Math.round(track.scrollLeft / carousel.step()));
    };
    track.addEventListener('pointerup', endDrag);
    track.addEventListener('pointercancel', endDrag);
    // Não segue o link "Saiba mais" ao arrastar
    track.addEventListener('click', (e) => {
      if (moved) {
        e.preventDefault();
        e.stopPropagation();
      }
    }, true);
  });
</script>
