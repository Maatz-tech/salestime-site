---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import EyebrowBadge from '../../components/EyebrowBadge.astro';
import ServiceHero from '../../components/sections/servicos/ServiceHero.astro';
import HeroStats from '../../components/sections/servicos/HeroStats.astro';
import LogosSection from '../../components/sections/LogosSection.astro';
import CtaFormSection from '../../components/sections/CtaFormSection.astro';
import FaqSection from '../../components/sections/FaqSection.astro';
import DiagnosticModal from '../../components/DiagnosticModal.astro';
import { ctaHref } from '../../data/site';

const icons = '/images/servicos/icons';

const etapas = [
  {
    icon: `${icons}/bullseye-crm.svg`,
    title: 'Planejamento',
    body: 'Planejamos o setup de cada software conforme as particularidades do negócio.',
  },
  {
    icon: `${icons}/master-plan.svg`,
    title: 'Integrações',
    body: 'Realizamos integrações no-code entre as suas ferramentas.',
  },
  {
    icon: `${icons}/team-check.svg`,
    title: 'Treinamento',
    body: 'Capacitamos o time de vendas e a liderança para o melhor uso.',
  },
  {
    icon: `${icons}/remote-access.svg`,
    title: 'Migração de dados',
    body: 'Realizamos a migração de dados de uma plataforma para outra.',
  },
  {
    icon: `${icons}/flag.svg`,
    title: 'Go live!',
    body: 'Acompanhamos de perto o momento de transição entre ferramentas.',
  },
];

const beneficios = [
  'Centralize todos os dados uma única plataforma',
  'Acompanhe métricas e indicadores em tempo real',
  'Otimize a rotina automatizando tarefas',
  'Tenha mais previsibilidade de receita',
];
---

<Base
  title="Implementação de CRM — Salestime"
  description="Desenhamos e implementamos a estrutura ideal de ferramentas de vendas para o seu time, alinhada com a estrutura do seu negócio."
>
  <Header />
  <main id="main">
    <ServiceHero
      eyebrow="Implementação de CRM"
      title="As ferramentas certas para o seu time vender mais e melhor"
      description="Desenhamos e implementamos a estrutura ideal de ferramentas de vendas para o seu time, alinhada com a estrutura do seu negócio."
      ctaLabel="Implementar meu CRM"
    >
      <HeroStats
        slot="visual"
        image="/images/servicos/crm-hero.webp"
        alt="Dupla comercial acompanhando indicadores do CRM no laptop"
      />
    </ServiceHero>

    <LogosSection />

    <!-- Como funciona: 5 etapas em grade 3 + 2 -->
    <section id="como-funciona" class="bg-gray-50 py-16 lg:py-20">
      <div class="shell flex flex-col gap-10">
        <div class="flex flex-col gap-4 lg:items-center lg:text-center">
          <p class="eyebrow eyebrow--lg text-blue-300">Como funciona</p>
          <h2 class="max-w-[685px] text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[36px]">
            Conheça nosso processo de implementação de softwares de vendas
          </h2>
        </div>
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-6">
          {etapas.map((etapa, i) => (
            <li
              class:list={[
                'crm-card flex flex-col gap-10 rounded-3xl p-6',
                i === 0 && 'is-active',
                i < 3 ? 'lg:col-span-2' : 'lg:col-span-3',
              ]}
            >
              <span class="flex size-14 items-center justify-center rounded-full bg-lemon" aria-hidden="true">
                <img src={etapa.icon} alt="" width="24" height="24" class="h-6 w-6" />
              </span>
              <div class="flex flex-col gap-3.5">
                <h3 class="crm-title text-2xl font-semibold leading-[1.3]">{i + 1}. {etapa.title}</h3>
                <p class="crm-body text-base font-normal leading-[1.5]">{etapa.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Por que implementar -->
    <section id="porque-implementar" class="bg-white py-16 lg:py-20">
      <div class="shell flex flex-col gap-10 lg:flex-row lg:items-center lg:gap-20">
        <div class="flex flex-col gap-4 lg:w-[588px] lg:shrink-0 lg:gap-10">
          <div class="flex flex-col gap-4">
            <p class="eyebrow eyebrow--lg text-blue-300">Porque implementar um CRM?</p>
            <h2 class="text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[36px]">
              Boas decisões começam com dados confiáveis
            </h2>
            <p class="text-lg font-normal leading-[1.5] text-gray-900">
              Ter um CRM bem implementado pode tornar seu time comercial mais eficiente
              e assertivo. Estruturamos sua ferramenta para que ela se torne o centro da
              operação comercial, conectando pessoas, processos e indicadores em um
              único lugar.
            </p>
          </div>
          <Button href={ctaHref} variant="primary" icon class="hidden self-start lg:inline-flex">
            Implementar meu CRM
          </Button>
        </div>

        <div class="flex min-w-0 flex-1 flex-col gap-4">
          {beneficios.map((b) => (
            <div class="flex items-center gap-4 rounded-2xl bg-gray-50 p-6">
              <span class="flex size-6 shrink-0 items-center justify-center rounded-full bg-lemon text-blue-600" aria-hidden="true">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5" /></svg>
              </span>
              <p class="text-lg font-semibold leading-[1.3] text-blue-900">{b}</p>
            </div>
          ))}
        </div>

        <Button href={ctaHref} variant="primary" icon class="w-full justify-between lg:hidden">
          Implementar meu CRM
        </Button>
      </div>
    </section>

    <!-- Tutorial Pipedrive -->
    <section id="tutorial" class="bg-gray-50 py-16 lg:py-20" aria-label="Tutorial de Pipedrive">
      <div class="shell">
        <div data-card class="flex flex-col gap-8 rounded-3xl bg-white p-6 sm:p-10 lg:flex-row lg:items-center lg:gap-12 lg:p-12">
          <a
            href="https://www.youtube.com/@salestime"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative block shrink-0 overflow-hidden rounded-2xl lg:w-[542px]"
            aria-label="Assistir ao tutorial completo de Pipedrive no YouTube"
          >
            <img
              src="/images/servicos/crm-felipe.webp"
              alt=""
              width="1084"
              height="610"
              loading="lazy"
              class="block aspect-[542/305] w-full object-cover transition-transform duration-500 motion-safe:group-hover:scale-[1.02]"
            />
            <!-- Overlay navy à direita (Figma) -->
            <div
              class="absolute inset-0"
              style="background-image: linear-gradient(270deg, rgba(10,7,85,0.45) 34.7%, rgba(10,7,85,0) 50%)"
              aria-hidden="true"
            >
            </div>
            <div class="absolute left-6 top-10 flex flex-col gap-3.5 sm:left-10 sm:top-14">
              <img
                src="/images/servicos/pipedrive-logo.webp"
                alt="Pipedrive"
                width="280"
                height="158"
                loading="lazy"
                class="h-8 w-auto self-start"
              />
              <p class="text-base font-semibold uppercase leading-none text-white">Guia completo para</p>
              <p class="text-[32px] font-extrabold uppercase leading-none text-lemon">Iniciantes</p>
            </div>
            <div class="absolute bottom-6 left-6 flex flex-col gap-1 sm:bottom-10 sm:left-10">
              <p class="text-base font-semibold leading-[1.3] text-white">Com Felipe Traina</p>
              <p class="text-sm font-normal leading-[1.3] text-white">CEO Salestime</p>
            </div>
            <span class="absolute bottom-8 right-10 flex size-16 items-center justify-center rounded-full bg-blue-300/20 text-white backdrop-blur-[2px] transition-transform motion-safe:group-hover:scale-110">
              <svg class="h-8 w-8" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6 4.75c0-1.36 1.48-2.2 2.65-1.52l12.4 7.25c1.16.68 1.16 2.36 0 3.04L8.65 20.77C7.48 21.45 6 20.61 6 19.25V4.75Z" />
              </svg>
            </span>
          </a>
          <div class="flex flex-col items-start gap-8">
            <div class="flex flex-col gap-4">
              <div class="flex items-center gap-3">
                <EyebrowBadge tone="brand" icon="play" />
                <p class="eyebrow eyebrow--lg text-blue-300">Tutorial completo</p>
              </div>
              <h2 class="text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[36px]">
                Aprenda a usar o Pipedrive do jeito certo
              </h2>
              <p class="text-base font-normal leading-[1.5] text-gray-900">
                Configure, personalize e gerencie seu CRM com mais eficiência através de
                um treinamento prático, criado para quem quer organizar o processo
                comercial e extrair o máximo da ferramenta.
              </p>
            </div>
            <Button
              href="https://www.youtube.com/@salestime"
              target="_blank"
              rel="noopener noreferrer"
              variant="primary"
              icon
            >
              Assistir treinamento
            </Button>
          </div>
        </div>
      </div>
    </section>

    <CtaFormSection
      eyebrow="Implemente seu CRM"
      title="Mais eficiência, controle e previsibilidade para sua operação comercial."
    />
    <FaqSection />
  </main>
  <Footer />
  <DiagnosticModal />
</Base>

<style>
  .crm-card {
    background-color: var(--color-white);
    transition: background-color 0.3s ease;
  }
  .crm-title {
    color: var(--color-blue-900);
    transition: color 0.3s ease;
  }
  .crm-body {
    color: var(--color-gray-900);
    transition: color 0.3s ease;
  }
  .crm-card.is-active,
  .crm-card:hover {
    background-color: var(--color-blue-600);
  }
  .crm-card.is-active .crm-title,
  .crm-card.is-active .crm-body,
  .crm-card:hover .crm-title,
  .crm-card:hover .crm-body {
    color: var(--color-white);
  }
  /* Hover em outro card "rouba" o destaque: o ativo aparece inativo */
  ul:has(.crm-card:hover) .crm-card.is-active:not(:hover) {
    background-color: var(--color-white);
  }
  ul:has(.crm-card:hover) .crm-card.is-active:not(:hover) .crm-title {
    color: var(--color-blue-900);
  }
  ul:has(.crm-card:hover) .crm-card.is-active:not(:hover) .crm-body {
    color: var(--color-gray-900);
  }
</style>
