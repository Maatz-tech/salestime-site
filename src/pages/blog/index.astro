---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/BlogCard.astro';
import NewsletterSection from '../../components/sections/NewsletterSection.astro';
import DiagnosticModal from '../../components/DiagnosticModal.astro';
import { blogCategories } from '../../data/site';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const featuredPost = sortedPosts.find((p) => p.data.featured) ?? sortedPosts[0];
const regularPosts = sortedPosts.filter((p) => p.id !== featuredPost.id);
const filters = ['Todos', ...blogCategories];

const formatDate = (dateStr: string) =>
  new Date(`${dateStr}T00:00:00`).toLocaleDateString('pt-BR', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  });
---

<Base
  title="Blog — Salestime"
  description="Conteúdos práticos sobre prospecção, pré-vendas, CRM e gestão comercial para acelerar as vendas do seu negócio."
>
  <Header />
  <main id="main">
    <!-- Hero -->
    <section class="relative overflow-hidden bg-gray-50">
      <img
        src="/images/sobre/hero-swoosh.svg"
        alt=""
        aria-hidden="true"
        width="790"
        height="753"
        class="pointer-events-none absolute right-[-138px] top-[-176px] hidden h-[753px] w-[790px] max-w-none lg:block"
      />
      <div class="shell relative flex flex-col gap-5 py-14 lg:items-center lg:py-20 lg:text-center">
        <div class="flex items-center gap-3">
          <img
            src="/images/sobre/eyebrow-icon.svg"
            alt=""
            aria-hidden="true"
            width="24"
            height="22"
            class="h-[22px] w-6"
          />
          <p class="eyebrow eyebrow--lg text-blue-300">Blog</p>
        </div>
        <h1 class="h1 max-w-[820px]">Conteúdos práticos para vender mais</h1>
        <p class="body-lg max-w-[560px]">
          Prospecção, pré-vendas, CRM e gestão comercial — o que aplicamos todos
          os dias em centenas de operações B2B.
        </p>
      </div>
    </section>

    <!-- Post em destaque -->
    <section class="bg-white py-12 lg:py-16" aria-label="Post em destaque">
      <div class="shell">
        <a
          href={`/blog/${featuredPost.id}`}
          data-card
          class="group flex flex-col overflow-hidden rounded-3xl border border-gray-100 bg-white transition-shadow duration-300 hover:shadow-[0px_12px_24px_rgba(10,7,85,0.08)] lg:flex-row"
        >
          <div class="overflow-hidden lg:w-1/2 lg:shrink-0">
            <img
              src={featuredPost.data.image}
              alt=""
              width="760"
              height="340"
              fetchpriority="high"
              class="block aspect-[760/340] w-full object-cover transition-transform duration-500 motion-safe:group-hover:scale-[1.03] lg:h-full lg:aspect-auto"
            />
          </div>
          <div class="flex flex-col gap-4 p-6 lg:justify-center lg:p-10">
            <p class="text-xs font-semibold uppercase tracking-[0.04em] text-blue-300">
              {featuredPost.data.category}
            </p>
            <h2 class="text-2xl font-semibold leading-[1.3] text-blue-900 transition-colors group-hover:text-blue-600 lg:text-[28px]">
              {featuredPost.data.title}
            </h2>
            <p class="text-base font-medium leading-[1.6] text-gray-600">
              {featuredPost.data.summary}
            </p>
            <div class="flex items-center gap-2.5 pt-1">
              <img
                src={featuredPost.data.authorImage}
                alt=""
                width="96"
                height="96"
                class="size-9 rounded-full object-cover"
              />
              <span class="text-sm font-semibold text-blue-900">{featuredPost.data.author}</span>
              <time
                datetime={featuredPost.data.date}
                class="text-sm font-medium text-gray-600"
              >
                · {formatDate(featuredPost.data.date)}
              </time>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- Todos os artigos -->
    <section class="bg-white pb-16 lg:pb-20">
      <div class="shell flex flex-col gap-8 lg:gap-10">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
          <h2 class="text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[32px]">
            Todos os artigos
          </h2>
          <!-- Filtros por categoria -->
          <div
            class="-mx-5 flex gap-3 overflow-x-auto px-5 [scrollbar-width:none] lg:mx-0 lg:px-0 [&::-webkit-scrollbar]:hidden"
            role="group"
            aria-label="Filtrar por categoria"
          >
            {filters.map((cat, i) => (
              <button
                type="button"
                data-blog-filter={cat}
                aria-pressed={i === 0 ? 'true' : 'false'}
                class:list={[
                  'blog-filter shrink-0 whitespace-nowrap rounded-full border px-5 py-2 text-sm font-semibold transition-colors',
                  i === 0
                    ? 'is-active border-blue-600 bg-blue-600 text-white'
                    : 'border-gray-200 bg-white text-blue-900 hover:border-blue-600 hover:text-blue-600',
                ]}
              >
                {cat}
              </button>
            ))}
          </div>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8" data-blog-grid>
          {regularPosts.map((post) => (
            <BlogCard
              slug={post.id}
              title={post.data.title}
              summary={post.data.summary}
              image={post.data.image}
              category={post.data.category}
              date={formatDate(post.data.date)}
              author={post.data.author}
              authorImage={post.data.authorImage}
              data-category={post.data.category}
            />
          ))}
        </div>

        <p class="hidden text-center text-base font-medium text-gray-600" data-blog-empty>
          Nenhum artigo nesta categoria ainda.
        </p>
      </div>
    </section>

    <NewsletterSection />
  </main>
  <Footer />
  <DiagnosticModal />
</Base>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('[data-blog-filter]');
  const cards = document.querySelectorAll<HTMLElement>('[data-blog-grid] [data-category]');
  const empty = document.querySelector<HTMLElement>('[data-blog-empty]');
  const activeClasses = ['is-active', 'border-blue-600', 'bg-blue-600', 'text-white'];
  const idleClasses = ['border-gray-200', 'bg-white', 'text-blue-900', 'hover:border-blue-600', 'hover:text-blue-600'];

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      filters.forEach((f) => {
        const active = f === btn;
        f.classList[active ? 'add' : 'remove'](...activeClasses);
        f.classList[active ? 'remove' : 'add'](...idleClasses);
        f.setAttribute('aria-pressed', String(active));
      });

      const category = btn.dataset.blogFilter;
      let visible = 0;
      cards.forEach((card) => {
        const show = category === 'Todos' || card.dataset.category === category;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      empty?.classList.toggle('hidden', visible > 0);
    });
  });
</script>
