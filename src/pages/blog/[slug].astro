---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/BlogCard.astro';
import NewsletterSection from '../../components/sections/NewsletterSection.astro';
import DiagnosticModal from '../../components/DiagnosticModal.astro';
import ArrowLeft from '../../components/icons/ArrowLeft.astro';
import ArrowRight from '../../components/icons/ArrowRight.astro';
import Linkedin from '../../components/icons/Linkedin.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);

// Navegação anterior/próximo e relacionados (mesma categoria primeiro)
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const currentIndex = sortedPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const relatedPosts = sortedPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => Number(b.data.category === post.data.category) - Number(a.data.category === post.data.category))
  .slice(0, 3);

const formatDate = (dateStr: string) =>
  new Date(`${dateStr}T00:00:00`).toLocaleDateString('pt-BR', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  });

const siteUrl = 'https://www.salestime.com.br';
const postUrl = `${siteUrl}/blog/${post.id}`;
const shareUrls = {
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(postUrl)}`,
  twitter: `https://twitter.com/intent/tweet?url=${encodeURIComponent(postUrl)}&text=${encodeURIComponent(post.data.title)}`,
  whatsapp: `https://api.whatsapp.com/send?text=${encodeURIComponent(`${post.data.title} ${postUrl}`)}`,
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.summary,
  image: new URL(post.data.image, siteUrl).href,
  datePublished: post.data.date,
  author: { '@type': 'Person', name: post.data.author },
  publisher: { '@type': 'Organization', name: 'Salestime', url: siteUrl },
};
---

<Base
  title={`${post.data.title} — Blog Salestime`}
  description={post.data.summary}
  image={post.data.image}
  ogType="article"
>
  <Header />
  <main id="main">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

    <!-- Hero do post -->
    <section class="relative overflow-hidden border-b border-gray-100 bg-gray-50">
      <div class="shell relative flex flex-col gap-8 py-12 lg:flex-row lg:items-center lg:gap-16 lg:py-16">
        <div class="flex min-w-0 flex-1 flex-col items-start gap-5">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 transition-colors hover:text-blue-900"
          >
            <ArrowLeft class="h-4 w-4" />
            Voltar para o blog
          </a>
          <p class="text-xs font-semibold uppercase tracking-[0.04em] text-blue-300">
            {post.data.category}
          </p>
          <h1 class="text-[28px] font-semibold leading-[1.3] text-blue-900 lg:text-[40px]">
            {post.data.title}
          </h1>
          {post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2.5">
              {post.data.tags.map((tag) => (
                <span class="rounded-full border border-gray-200 bg-white px-4 py-1.5 text-sm font-medium text-blue-600">
                  {tag}
                </span>
              ))}
            </div>
          )}
          <div class="flex items-center gap-2.5">
            <img
              src={post.data.authorImage}
              alt={post.data.author}
              width="96"
              height="96"
              class="size-9 rounded-full object-cover"
            />
            <span class="text-sm font-semibold text-blue-900">{post.data.author}</span>
            <time datetime={post.data.date} class="text-sm font-medium text-gray-600">
              · {formatDate(post.data.date)}
            </time>
          </div>
        </div>
        <div class="w-full shrink-0 lg:w-[480px]">
          <img
            src={post.data.image}
            alt=""
            width="760"
            height="340"
            fetchpriority="high"
            class="block w-full rounded-3xl object-cover"
          />
        </div>
      </div>
    </section>

    <!-- Corpo do artigo -->
    <article class="bg-white py-12 lg:py-16">
      <div class="shell">
        <div class="post-body mx-auto flex max-w-[760px] flex-col gap-6">
          <Content />
        </div>

        <div class="mx-auto max-w-[760px]">
          <hr class="my-10 border-gray-100" />

          <!-- Autor + compartilhar -->
          <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex items-center gap-3">
              <img
                src={post.data.authorImage}
                alt={post.data.author}
                width="96"
                height="96"
                loading="lazy"
                class="size-11 rounded-full object-cover"
              />
              <div class="flex flex-col">
                <span class="text-base font-semibold text-blue-900">{post.data.author}</span>
                <span class="text-sm font-medium text-gray-600">{post.data.authorRole}</span>
              </div>
            </div>
            <div class="flex items-center gap-3.5">
              <span class="text-base font-medium text-blue-900">Compartilhe</span>
              <div class="flex items-center gap-2.5">
                <a
                  href={shareUrls.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Compartilhar no LinkedIn"
                  class="flex size-9 items-center justify-center rounded-full bg-blue-600 text-white transition-colors hover:bg-blue-900"
                >
                  <Linkedin class="h-4 w-4" />
                </a>
                <a
                  href={shareUrls.whatsapp}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Compartilhar no WhatsApp"
                  class="flex size-9 items-center justify-center rounded-full bg-blue-600 text-white transition-colors hover:bg-blue-900"
                >
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                </a>
                <a
                  href={shareUrls.twitter}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Compartilhar no X"
                  class="flex size-9 items-center justify-center rounded-full bg-blue-600 text-white transition-colors hover:bg-blue-900"
                >
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <button
                  type="button"
                  id="copy-link-btn"
                  data-url={postUrl}
                  aria-label="Copiar link"
                  class="flex size-9 cursor-pointer items-center justify-center rounded-full bg-blue-600 text-white transition-colors hover:bg-blue-900"
                >
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                </button>
              </div>
            </div>
          </div>

          <hr class="my-10 border-gray-100" />

          <!-- Anterior / Próximo -->
          <nav class="flex items-center justify-between gap-4" aria-label="Outros posts">
            {prevPost ? (
              <a
                href={`/blog/${prevPost.id}`}
                class="inline-flex items-center gap-2 text-base font-semibold text-blue-600 transition-colors hover:text-blue-900"
              >
                <ArrowLeft class="h-5 w-5" />
                Anterior
              </a>
            ) : (
              <span />
            )}
            {nextPost ? (
              <a
                href={`/blog/${nextPost.id}`}
                class="inline-flex items-center gap-2 text-base font-semibold text-blue-600 transition-colors hover:text-blue-900"
              >
                Próximo
                <ArrowRight class="h-5 w-5" />
              </a>
            ) : (
              <span />
            )}
          </nav>
        </div>
      </div>
    </article>

    <!-- Posts relacionados -->
    <section class="bg-gray-50 py-16 lg:py-20" aria-label="Posts relacionados">
      <div class="shell flex flex-col gap-8 lg:gap-10">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
          <h2 class="text-[24px] font-semibold leading-[1.4] text-blue-900 lg:text-[32px]">
            Leia mais artigos
          </h2>
          <a
            href="/blog"
            class="btn btn--outline btn--md self-start bg-white lg:self-auto"
          >
            Ver todos
            <ArrowRight class="h-[18px] w-[18px]" />
          </a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 lg:gap-8">
          {relatedPosts.map((related) => (
            <BlogCard
              slug={related.id}
              title={related.data.title}
              summary={related.data.summary}
              image={related.data.image}
              category={related.data.category}
              date={formatDate(related.data.date)}
              author={related.data.author}
              authorImage={related.data.authorImage}
            />
          ))}
        </div>
      </div>
    </section>

    <NewsletterSection />
  </main>
  <Footer />
  <DiagnosticModal />
</Base>

<script>
  const copyBtn = document.getElementById('copy-link-btn');
  copyBtn?.addEventListener('click', async () => {
    const url = copyBtn.getAttribute('data-url');
    if (!url) return;
    try {
      await navigator.clipboard.writeText(url);
      const prev = copyBtn.getAttribute('aria-label');
      copyBtn.setAttribute('aria-label', 'Link copiado!');
      setTimeout(() => copyBtn.setAttribute('aria-label', prev ?? 'Copiar link'), 2000);
    } catch {
      window.prompt('Copie o link:', url);
    }
  });
</script>

<style>
  /* Tipografia do Markdown do post */
  .post-body :global(p) {
    font-size: 18px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-gray-900);
  }
  .post-body :global(h2) {
    margin-top: 16px;
    font-size: 24px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-blue-900);
  }
  .post-body :global(h3) {
    margin-top: 8px;
    font-size: 20px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-blue-900);
  }
  .post-body :global(strong) {
    font-weight: 700;
    color: var(--color-blue-900);
  }
  .post-body :global(a) {
    font-weight: 600;
    color: var(--color-blue-300);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .post-body :global(a:hover) {
    color: var(--color-blue-900);
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-left: 24px;
    font-size: 18px;
    line-height: 1.6;
    color: var(--color-gray-900);
  }
  .post-body :global(ul) {
    list-style: disc;
  }
  .post-body :global(ol) {
    list-style: decimal;
  }
  .post-body :global(li)::marker {
    color: var(--color-blue-300);
  }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-blue-300);
    padding-left: 20px;
    font-style: italic;
    color: var(--color-gray-600);
  }
  .post-body :global(code) {
    background-color: var(--color-gray-50);
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 15px;
  }
  .post-body :global(pre) {
    background-color: var(--color-gray-50);
    border-radius: 12px;
    padding: 20px;
    overflow-x: auto;
  }
  .post-body :global(pre code) {
    background: none;
    padding: 0;
  }
  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 16px;
  }
</style>
